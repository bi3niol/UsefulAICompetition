{
    "version": "2.0",
    "logging": {
        "applicationInsights": {
            "samplingSettings": {
                "isEnabled": true,
                "excludedTypes": "Request"
            },
            "enableLiveMetricsFilters": true
        }
    },
    "extensions": {
        "serviceBus": {
            // Throttling konsumentów — dobrane pod limity Embedding API i DevOps REST API.
            // W razie potrzeby można podnieść po zwiększeniu kwot.
            "maxConcurrentCalls": 4,
            "prefetchCount": 8,
            "maxAutoLockRenewalDuration": "00:10:00"
        }
    }
}